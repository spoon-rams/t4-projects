{{#ifSet element="Social Share Title"}}
 <!-- og:title -->
 <meta property="og:title" content='{{publish element="Social Share Title"}}'>
{{/ifSet}}

{{#ifSet element="Social Share Image"}}
 <!-- og:image -->
 <meta property="og:image" content='https://www.fordham.edu{{{media id=(mediaId element="Social Share Image") layout="path/*"}}}' >
 <!-- og:dimensions -->
 <meta property="og:image:width" content="1200">
 <meta property="og:image:height" content="630">
{{/ifSet}}

{{#ifSet element="Social Share Image Alternative Text"}}
 <!-- og:alt image text -->
 <meta property="og:image:alt" content='{{publish element="Social Share Image Alternative Text"}}'>
{{/ifSet}}

{{#ifSet element="Social Share Description"}}
 <!-- og:description -->
 <meta property="og:description" content='{{publish element="Social Share Description"}}' >
{{/ifSet}}

{{#ifSet element="Social Share Title"}}
 <!-- twitter meta title -->
 <meta name="twitter:title" content='{{publish element="Social Share Title"}}'>
{{/ifSet}}

{{#ifSet element="Social Share Image"}}
 <!-- twitter meta tags -->
 <meta name="twitter:card" content="summary_large_image">
 <meta name="twitter:site" content="@FordhamNYC">
 <meta name="twitter:image" property="og:image" content='https://www.fordham.edu{{{media id=(mediaId element="Social Share Image") layout="path/*"}}}' >
{{/ifSet}}

{{#ifSet element="Social Share Description"}}>
 <meta name="twitter:description" content='{{publish element="Social Share Description"}}' >
{{/ifSet}}